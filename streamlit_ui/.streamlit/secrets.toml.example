# Copy this file to `secrets.toml` (same folder) for local dev.
# On Streamlit Community Cloud, set the same key via:
#   App → Settings → Secrets   (paste the line below, with your real value)
#
# If `app_password` is missing or empty, the password gate is disabled
# and the app is open — useful for local dev without a secrets file.

app_password = "change-me-before-deploying"
